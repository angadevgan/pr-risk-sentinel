# --- GitHub App credentials (from https://github.com/settings/apps) ---
APP_ID=
PRIVATE_KEY_PATH=./private-key.pem
WEBHOOK_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Backfill script (separate from App credentials) ---
# Personal Access Token with repo:read scope, used only by scripts/backfill.js
GITHUB_TOKEN=

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/pr_risk_sentinel

# --- Server ---
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
DASHBOARD_URL=http://localhost:5173

# --- Debug ---
LOG_QUERIES=false
